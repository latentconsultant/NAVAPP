@model IEnumerable<navigateapp.Models.Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="container-fluid mt-4">
    <div class="glass-panel p-4 rounded-4">
        <h2 class="text-white mb-4">Customer Management</h2>

        <div class="row">
            <div class="col-md-4">
                <div class="glass-panel p-3 rounded-3 mb-4">
                    <h4 class="text-info">Add Customer</h4>
                    <form asp-action="CreateCustomer" method="post">
                        <div class="form-group mb-3">
                            <label class="control-label text-white">Name</label>
                            <input name="Name" class="form-control bg-dark text-white border-secondary" required />
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label text-white">Email</label>
                            <input name="Email" type="email" class="form-control bg-dark text-white border-secondary" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label text-white">Phone</label>
                            <input name="PhoneNumber" class="form-control bg-dark text-white border-secondary" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="control-label text-white">Company</label>
                            <input name="Company" class="form-control bg-dark text-white border-secondary" />
                        </div>
                        <button type="submit" class="btn btn-success w-100 glow-button">Save Customer</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="glass-panel p-3 rounded-3">
                    <h4 class="text-white mb-3">Customer List</h4>
                    <div class="table-responsive">
                        <table class="table text-white">
                            <thead>
                                <tr>
                                    <th class="text-white" style="border-bottom: 2px solid #00f2ff;">Name</th>
                                    <th class="text-white" style="border-bottom: 2px solid #00f2ff;">Email</th>
                                    <th class="text-white" style="border-bottom: 2px solid #00f2ff;">Company</th>
                                    <th class="text-white" style="border-bottom: 2px solid #00f2ff;">Last Follow-up</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null)
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.Email</td>
                                            <td>@item.Company</td>
                                            <td>@item.LastFollowUp.ToShortDateString()</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <div class="glass-panel p-4 rounded-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white">Logistics Admin Dashboard</h2>
            <a asp-action="Logout" class="btn btn-outline-danger glow-button">Logout</a>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="glass-panel mb-4 p-3 rounded-3">
                    <div class="card-body text-black">
                        <h5 class="card-title text-black">Bills of Lading</h5>
                        <h2 class="display-4 text-black">@(ViewBag.BillCount ?? 0)</h2>
                        <p class="card-text text-black">Total documents stored.</p>
                    </div>
                    <div class="mt-3">
                        <a class="btn btn-info btn-sm w-100" asp-action="Bills">View Details</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel mb-4 p-3 rounded-3">
                    <div class="card-body text-black">
                        <h5 class="card-title text-black">Customers</h5>
                        <h2 class="display-4 text-black">@(ViewBag.CustomerCount ?? 0)</h2>
                        <p class="card-text text-black">Total customers in database.</p>
                    </div>
                    <div class="mt-3">
                        <a class="btn btn-info btn-sm w-100" asp-action="Customers">Manage CRM</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel mb-4 p-3 rounded-3">
                    <div class="card-body text-black">
                        <h5 class="card-title text-black">Fleet Size</h5>
                        <h2 class="display-4 text-black">@(ViewBag.VehicleCount ?? 0)</h2>
                        <p class="card-text text-black">Active vehicles tracked.</p>
                    </div>
                    <div class="mt-3">
                        <a class="btn btn-info btn-sm w-100" asp-action="Vehicles">Manage Fleet</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="glass-panel mt-4 p-3 rounded-3">
            <div class="border-bottom border-secondary mb-3 pb-2">
                <h4 class="text-white">Quick Actions & System Status</h4>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <h5 class="text-info">Recent Activity</h5>
                    <ul class="list-group list-group-flush bg-transparent">
                        <li class="list-group-item bg-transparent text-white-50 border-secondary">Admin login successful.</li>
                        <li class="list-group-item bg-transparent text-white-50 border-secondary">Database synchronization complete.</li>
                    </ul>
                </div>
                <div class="col-md-6 text-center">
                    <h5 class="text-black">System Status</h5>
                    <div class="alert alert-dark border-info text-black bg-opacity-75">
                        <strong>All systems operational.</strong><br />
                        Geocoding Service: Connected<br />
                        Database: SQL Server (Healthy)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

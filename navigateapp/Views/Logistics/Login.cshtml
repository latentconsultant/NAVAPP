@{
    ViewData["Title"] = "Admin Login";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card mt-5 shadow-lg border-info">
            <div class="card-header border-bottom border-info">
                <h3 class="text-center text-info">Admin Login</h3>
            </div>
            <div class="card-body bg-dark text-white rounded-bottom">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form asp-action="Login" method="post">
                    <div class="form-group mb-3">
                        <label class="control-label text-white-50">Username</label>
                        <input name="username" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label text-white-50">Password</label>
                        <input name="password" type="password" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary glow-button">Login</button>
                    </div>
                </form>
                <div class="mt-3 text-center text-white-50">
                    <small>Default: admin / admin123</small>
                </div>
            </div>
        </div>
    </div>
</div>
